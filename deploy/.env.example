# deploy/.env.example — Environment variables for Docker deployment
#
# Copy to deploy/.env and fill in the values before running:
#   cp deploy/.env.example deploy/.env
#   docker compose --env-file deploy/.env up -d

# REQUIRED: JWT secret key for signing access/refresh tokens
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=changeme-generate-a-real-secret-key

# Redis URL (internal Docker network)
REDIS_URL=redis://redis:6379/0

# Database path (inside container, mapped to volume)
DB_PATH=/data/danwa.db

# CORS origins (JSON array of allowed frontend URLs)
CORS_ORIGINS=["https://danwa.example.com"]

# Celery worker concurrency
CELERY_WORKER_CONCURRENCY=4

# Debug mode (set to "true" for development only)
DEBUG=false
